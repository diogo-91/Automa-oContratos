    "typecheck": "tsc --noEmit",
    "authorize-drive": "tsx scripts/authorize-google-drive.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.3",
    "docxtemplater": "^3.59.4",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "form-data": "^4.0.1",
    "googleapis": "^144.0.0",
    "pdf-parse": "^1.1.1",
    "pizzip": "^3.1.7",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.4",
    "@types/pdf-parse": "^1.1.4",
    "pm2": "^5.4.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
