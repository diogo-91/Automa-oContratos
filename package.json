{
  "name": "contract-automation",
  "version": "1.0.0",
  "description": "Automação de contratos com IA (Claude + Gemini)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "pm2 start ecosystem.config.js",
    "start:node": "node dist/index.js",
    "stop": "pm2 stop contract-automation",
