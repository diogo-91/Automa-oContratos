# ──────────────────────────────────────────────────────────
#  CONTRACT AUTOMATION — Variáveis de Ambiente
# ──────────────────────────────────────────────────────────

# ── IAs ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Google Drive ──────────────────────────────────────────
# Caminho para o arquivo JSON da Service Account do Google
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google-service-account.json

# ID da pasta "CONTRATOS" no Google Drive
# (abra a pasta no Drive — o ID está na URL após /folders/)
GOOGLE_DRIVE_CONTRATOS_FOLDER_ID=

# ID da pasta "MODELO DE CONTRATO" que contém Contrato_ECL.docx
GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=

# Intervalo de polling do Drive em milissegundos (padrão: 120000 = 2 min)
DRIVE_POLL_INTERVAL_MS=120000

# ── APIs externas ─────────────────────────────────────────
BRASIL_API_URL=https://brasilapi.com.br/api/cnpj/v1
REGISTRO_IMOVEIS_API_KEY=

# ── Evolution API (WhatsApp) ──────────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ── Logger ────────────────────────────────────────────────
LOG_LEVEL=info
